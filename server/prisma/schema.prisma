generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  password            String
  role                Role
  orgId               String?   @map("org_id") @db.Uuid
  org                 Organization? @relation(fields: [orgId], references: [id])
  encryptedKeyBlob    String?   @map("encrypted_key_blob")
  nostrPubkey         String?   @map("nostr_pubkey") @db.VarChar(128)
  keyBackupCompleted  Boolean   @default(false) @map("key_backup_completed")
  canEditSurveys      Boolean   @default(false) @map("can_edit_surveys")
  canEditThemes       Boolean   @default(false) @map("can_edit_themes")
  orgRoleId           String?   @map("org_role_id") @db.Uuid
  orgRole             OrgRole?  @relation(fields: [orgRoleId], references: [id], onDelete: SetNull)
  encryptedLevelKey   String?   @map("encrypted_level_key")
  approvedAt          DateTime? @map("approved_at")
  approvedBy          String?   @map("approved_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  surveyThemes   SurveyTheme[]
  createdInvites Invite[]      @relation("InviteCreator")

  @@map("users")
}

model Organization {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String
  plan                  Plan     @default(STARTER)
  rpgPublicKey          String?  @map("rpg_public_key")
  odvPublicKey          String?  @map("odv_public_key")
  relayUrls             Json     @default("[]") @map("relay_urls")
  pairingQrData         Json?    @map("pairing_qr_data")
  pairingSecret         String?  @map("pairing_secret")
  wbSlaAckDays          Int      @default(7) @map("wb_sla_ack_days")
  wbSlaResponseDays     Int      @default(90) @map("wb_sla_response_days")
  pdrSlaAckDays         Int      @default(3) @map("pdr_sla_ack_days")
  pdrSlaResponseDays    Int      @default(45) @map("pdr_sla_response_days")
  subscriptionExpires   DateTime? @map("subscription_expires")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  levelPubKeys          Json?    @map("level_pub_keys")

  users           User[]
  reportMetadata  ReportMetadata[]
  surveys         Survey[]
  surveyResponses SurveyResponse[]
  escrowShares    EscrowShare[]
  invites         Invite[]
  surveyThemes    SurveyTheme[]
  dashboards      Dashboard[]
  orgRoles        OrgRole[]

  @@map("organizations")
}

model Invite {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  org         Organization @relation(fields: [orgId], references: [id])
  role        String
  token       String    @unique @default(uuid()) @db.Uuid
  email       String?
  claimed     Boolean   @default(false)
  claimedAt   DateTime? @map("claimed_at")
  expiresAt   DateTime  @map("expires_at")
  createdById String?   @map("created_by_id") @db.Uuid
  createdBy   User?     @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  orgRoleId   String?   @map("org_role_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("invites")
}

model OrgRole {
  id          String       @id @default(uuid()) @db.Uuid
  orgId       String       @map("org_id") @db.Uuid
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  dataLevel   Int          @map("data_level")
  isBuiltin   Boolean      @default(false) @map("is_builtin")
  levelPubKey String?      @map("level_pub_key")
  createdAt   DateTime     @default(now()) @map("created_at")

  users       User[]

  @@unique([orgId, slug])
  @@map("org_roles")
}

model ReportMetadata {
  id                  String        @id @default(uuid()) @db.Uuid
  orgId               String        @map("org_id") @db.Uuid
  org                 Organization  @relation(fields: [orgId], references: [id])
  channel             ReportChannel
  category            String?
  status              ReportStatus  @default(RECEIVED)
  identityRevealed    Boolean?      @map("identity_revealed")
  hasAttachments      Boolean?      @map("has_attachments")
  receivedAt          DateTime      @default(now()) @map("received_at")
  acknowledgedAt      DateTime?     @map("acknowledged_at")
  responseGivenAt     DateTime?     @map("response_given_at")
  closedAt            DateTime?     @map("closed_at")
  slaAckDeadline      DateTime?     @map("sla_ack_deadline")
  slaResponseDeadline DateTime?     @map("sla_response_deadline")
  slaAckMet           Boolean?      @map("sla_ack_met")
  slaResponseMet      Boolean?      @map("sla_response_met")
  correctiveAction    String?       @map("corrective_action")
  nostrPubkey         String?       @map("nostr_pubkey") @db.VarChar(64)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@index([orgId, channel])
  @@index([orgId, status])
  @@index([slaAckDeadline])
  @@index([slaResponseDeadline])
  @@map("report_metadata")
}

model Survey {
  id          String       @id @default(uuid()) @db.Uuid
  orgId       String       @map("org_id") @db.Uuid
  org         Organization @relation(fields: [orgId], references: [id])
  title       String
  description String?
  schema      Json
  version     Int          @default(1)
  status      SurveyStatus @default(DRAFT)
  channel     String?
  icon        String?
  themeId     String?      @map("theme_id") @db.Uuid
  theme       SurveyTheme? @relation(fields: [themeId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  responses SurveyResponse[]

  @@index([orgId, status])
  @@map("surveys")
}

model SurveyResponse {
  id          String       @id @default(uuid()) @db.Uuid
  surveyId    String       @map("survey_id") @db.Uuid
  survey      Survey       @relation(fields: [surveyId], references: [id])
  orgId       String       @map("org_id") @db.Uuid
  org         Organization @relation(fields: [orgId], references: [id])
  answers     Json
  version     Int
  submittedAt DateTime     @default(now()) @map("submitted_at")

  @@index([surveyId])
  @@index([orgId, surveyId])
  @@map("survey_responses")
}

model EscrowShare {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  org          Organization @relation(fields: [orgId], references: [id])
  channel      ReportChannel
  shareIndex   Int          @map("share_index")
  encryptedShare String     @map("encrypted_share")
  holderEmail  String       @map("holder_email")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@unique([orgId, channel, shareIndex])
  @@map("escrow_shares")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RPG
  ODV
  TECHNICAL

  @@map("role")
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE

  @@map("plan")
}

enum ReportChannel {
  PDR125
  WHISTLEBLOWING

  @@map("report_channel")
}

enum ReportStatus {
  RECEIVED
  ACKNOWLEDGED
  INVESTIGATING
  RESPONSE_GIVEN
  CLOSED_FOUNDED
  CLOSED_UNFOUNDED
  CLOSED_BAD_FAITH

  @@map("report_status")
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED

  @@map("survey_status")
}

model SurveyTheme {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  description String?
  config      Json
  isBuiltin   Boolean      @default(false) @map("is_builtin")
  isPublic    Boolean      @default(false) @map("is_public")
  clonedFrom  String?      @map("cloned_from") @db.Uuid
  createdBy   String?      @map("created_by") @db.Uuid
  creator     User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  orgId       String?      @map("org_id") @db.Uuid
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  surveys     Survey[]

  @@index([orgId])
  @@map("survey_themes")
}

model NostrEvent {
  id         String   @id @db.VarChar(64)  // sha256 hex event id
  pubkey     String   @db.VarChar(64)
  kind       Int
  content    String
  tags       Json
  sig        String   @db.VarChar(128)
  createdAt  Int      @map("created_at")   // unix timestamp from event
  receivedAt DateTime @default(now()) @map("received_at")
  processed  Boolean  @default(false)

  @@index([kind])
  @@index([pubkey])
  @@map("nostr_events")
}

model Dashboard {
  id          String       @id @default(uuid()) @db.Uuid
  orgId       String       @map("org_id") @db.Uuid
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  surveyId    String?      @map("survey_id") @db.Uuid
  channel     String?
  title       String
  config      Json
  accessLevel Int          @default(1) @map("access_level")
  isDefault   Boolean      @default(false) @map("is_default")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([orgId, channel])
  @@map("dashboards")
}

model DashboardTemplate {
  id                 String   @id @default(uuid()) @db.Uuid
  slug               String   @unique
  config             Json
  catalogTitle       Json     @map("catalog_title")
  catalogDescription Json     @map("catalog_description")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("dashboard_templates")
}

model AuditLogEntry {
  id         String   @id @default(uuid()) @db.Uuid
  sequence   Int      @default(autoincrement())
  entityType String   @map("entity_type") @db.VarChar(64)
  entityId   String   @map("entity_id") @db.Uuid
  action     String   @db.VarChar(32)
  dataHash   String   @map("data_hash") @db.VarChar(64)
  prevHash   String   @map("prev_hash") @db.VarChar(64)
  chainHash  String   @map("chain_hash") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([sequence])
  @@map("audit_log")
}

model FormTemplate {
  id                 String   @id @default(uuid()) @db.Uuid
  slug               String   @unique
  title              String
  description        String?
  schema             Json
  channel            String?
  icon               String?
  catalogTitle       Json
  catalogDescription Json     @map("catalog_description")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("form_templates")
}
